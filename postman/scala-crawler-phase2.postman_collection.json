{
  "info": {
    "_postman_id": "f7ea7821-3d22-4b13-8f63-57f2e9dc7780",
    "name": "Scala Crawler - Phase 2",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json",
    "description": "Phase 2 control-plane API checks for jobs and tasks."
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:8080"
    },
    {
      "key": "domain",
      "value": "example.com"
    },
    {
      "key": "jobId",
      "value": "1"
    },
    {
      "key": "taskId",
      "value": "1"
    }
  ],
  "item": [
    {
      "name": "Health",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{baseUrl}}/health",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "health"
          ]
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('Status is 200', function () {",
              "  pm.response.to.have.status(200);",
              "});"
            ]
          }
        }
      ]
    },
    {
      "name": "Create Job",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"domain\": \"{{domain}}\"\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/jobs",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "jobs"
          ]
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('Status is 201', function () {",
              "  pm.response.to.have.status(201);",
              "});",
              "const json = pm.response.json();",
              "if (json && json.id) {",
              "  pm.collectionVariables.set('jobId', String(json.id));",
              "}"
            ]
          }
        }
      ]
    },
    {
      "name": "Get Job",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{baseUrl}}/jobs/{{jobId}}",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "jobs",
            "{{jobId}}"
          ]
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('Status is 200', function () {",
              "  pm.response.to.have.status(200);",
              "});",
              "const json = pm.response.json();",
              "pm.test('Default caps exist', function () {",
              "  pm.expect(json.config.max_audit_urls).to.eql(10);",
              "  pm.expect(json.config.audit_runs_per_url).to.eql(3);",
              "});"
            ]
          }
        }
      ]
    },
    {
      "name": "Get Job Report (placeholder)",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{baseUrl}}/jobs/{{jobId}}/report",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "jobs",
            "{{jobId}}",
            "report"
          ]
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('Status is 200', function () {",
              "  pm.response.to.have.status(200);",
              "});"
            ]
          }
        }
      ]
    },
    {
      "name": "Resume Job (placeholder)",
      "request": {
        "method": "POST",
        "header": [],
        "url": {
          "raw": "{{baseUrl}}/jobs/{{jobId}}/resume",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "jobs",
            "{{jobId}}",
            "resume"
          ]
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('Status is 202', function () {",
              "  pm.response.to.have.status(202);",
              "});"
            ]
          }
        }
      ]
    },
    {
      "name": "Lease Task",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"worker_id\": \"postman-worker\",\n  \"lease_ttl_seconds\": 300\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/tasks/lease",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "tasks",
            "lease"
          ]
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('Status is 200', function () {",
              "  pm.response.to.have.status(200);",
              "});",
              "const json = pm.response.json();",
              "if (json && json.task && json.task.id) {",
              "  pm.collectionVariables.set('taskId', String(json.task.id));",
              "}"
            ]
          }
        }
      ]
    },
    {
      "name": "Complete Task",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"result_json\": {\n    \"source\": \"postman\"\n  },\n  \"last_error\": null\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/tasks/{{taskId}}/complete",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "tasks",
            "{{taskId}}",
            "complete"
          ]
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('Status is 200 or 404', function () {",
              "  pm.expect([200, 404]).to.include(pm.response.code);",
              "});"
            ]
          }
        }
      ]
    }
  ]
}
